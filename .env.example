# ============================================================================
# NVIDIA Startup AI Radar — variáveis de ambiente (MODELO)
# ----------------------------------------------------------------------------
# Copie este arquivo para `.env` e preencha com valores reais.
# O `.env` NUNCA é commitado (está no .gitignore). Este `.env.example` sim.
# Nunca hardcodar credenciais no código — tudo é lido daqui.
# ============================================================================

# ----------------------------------------------------------------------------
# LLM Provider
# LLM_PROVIDER é o seletor: permite trocar de provider sem alterar código.
# Valores possíveis: openrouter | groq | gemini
# ----------------------------------------------------------------------------
LLM_PROVIDER=openrouter

# OpenRouter — provider principal (acesso unificado a múltiplos modelos)
OPENROUTER_API_KEY=
# ID do modelo no OpenRouter (ex.: anthropic/claude-3.5-sonnet, openai/gpt-4o, etc.)
OPENROUTER_MODEL=

# Groq — alternativa para chamadas de baixa latência
GROQ_API_KEY=

# Google Gemini — alternativa para contextos longos
GEMINI_API_KEY=

# ----------------------------------------------------------------------------
# Reranking e Scraping
# ----------------------------------------------------------------------------
# Cohere Rerank — reranking dos trechos recuperados no RAG (Bloco 2)
COHERE_API_KEY=

# Firecrawl — converte páginas em markdown limpo para o RAG
FIRECRAWL_API_KEY=

# ----------------------------------------------------------------------------
# PostgreSQL — dados estruturados de startups
# Os campos separados são usados pelo Docker Compose para criar o banco.
# A DATABASE_URL (redundante de propósito) é usada pela aplicação Python.
# Mantenha senha/usuário/db consistentes entre os dois.
# ----------------------------------------------------------------------------
POSTGRES_USER=radar
POSTGRES_PASSWORD=
POSTGRES_DB=radar
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://radar:senha@localhost:5432/radar

# ----------------------------------------------------------------------------
# Qdrant — banco vetorial do RAG
# QDRANT_API_KEY é opcional no ambiente local (deixe vazio).
# ----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ----------------------------------------------------------------------------
# PENDENTE — Provider de embeddings (decisão adiada, ver Bloco 2)
# O CLAUDE.md ainda não define qual usar. Opções: OpenAI, Cohere, Gemini ou
# um modelo local (sentence-transformers, sem custo/API). Descomentar e
# preencher quando a decisão for tomada.
# ----------------------------------------------------------------------------
# EMBEDDINGS_PROVIDER=
# EMBEDDINGS_MODEL=
# EMBEDDINGS_API_KEY=
